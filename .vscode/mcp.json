{
    "servers": {
        "remembrances":{
            "type": "http",
            "url": "http://localhost:3030/mcp"
        },
        "mesnada":{
            "type": "http",
            "url": "http://127.0.0.1:8765/mcp"
        },
        "hyper-mcp":{
            "type": "stdio",
            "command": "wsl",
            "args": [
                "-d",
                "Ubuntu",
                "hyper-mcp",
                "--config-file",
                "$HOME/.config/hyper-mcp/config.json"
            ],
            "env": {
                "SERPER_API_KEY": "${env:SERPER_API_KEY}"
            }
        }
    }
}