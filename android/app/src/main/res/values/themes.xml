<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.StarWarsApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/sw_black</item>
    </style>

    <style name="Theme.StarWarsApp.Splash" parent="Theme.SplashScreen">
